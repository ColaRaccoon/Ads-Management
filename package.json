{
  "name": "meta-ads-performance-hub",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:api": "npm --workspace @meta-ads-performance/api run start:dev",
    "dev:web": "npm --workspace @meta-ads-performance/web run dev",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "prisma:validate": "node scripts/prisma-validate.mjs",
    "prisma:generate": "npm --workspace @meta-ads-performance/api run prisma:generate",
    "prisma:migrate": "npm --workspace @meta-ads-performance/api run prisma:migrate",
    "prisma:seed": "npm --workspace @meta-ads-performance/api run prisma:seed"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
